  canonical="https://lvappraisalco.com/404"
>

  <div class="service-page-header">
    <div class="narrow">
      <p class="eyebrow">404</p>
      <h1>We couldn't find that page</h1>
      <p style="color: var(--text-secondary); margin-top: 16px; font-size: 1.05rem;">
        The page you're looking for may have moved or no longer exists. Here are some places to start instead.
      </p>
    </div>
  </div>

  <section>
    <div class="service-content">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About Las Vegas Appraisal Co.</a></li>
        <li><a href="/lenders">Appraisals for Lenders</a></li>
        <li><a href="/litigation-appraisals">Litigation Appraisals</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/faq">FAQ</a></li>
        <li><a href="/contact">Contact Us</a></li>
      </ul>

      <div class="service-cta">
        <p>Looking for a specific appraisal service? Just give us a call.</p>
        <a href="tel:+17028949279" class="btn btn-primary">(702) 894-9279</a>
      </div>
    </div>
  </section>

